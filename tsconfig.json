{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "forceConsistentCasingInFileNames": true,
    "suppressImplicitAnyIndexErrors": true,
    "incremental": true,
    "strict": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "Node",
    "lib": ["DOM", "ES2018"],
    "allowJs": true,
    "jsx": "react",
    "sourceMap": true,
    "outDir": "./public/dist",
    "baseUrl": ".",
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS"
    }
  },
  "include": ["src/**/*", "webpack.config.ts"]
}
